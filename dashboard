<script>
// === ROS CONNECTION ===
var ros = new ROSLIB.Ros({
  url: 'ws://localhost:9090'
});

ros.on('connection', function() {
  addFeed('green', 'Connected to ROS bridge', 'now');
});
ros.on('error', function() {
  addFeed('red', 'ROS connection error', 'now');
});
ros.on('close', function() {
  addFeed('amber', 'ROS bridge disconnected', 'now');
});

// === BATTERY TOPIC ===
var batteryTopic = new ROSLIB.Topic({
  ros: ros,
  name: '/drone/battery',
  messageType: 'sensor_msgs/BatteryState'
});

batteryTopic.subscribe(function(msg) {
  var droneId = msg.header.frame_id;
  var pct = Math.round(msg.percentage * 100);
  updateBatteryBar(droneId, pct);
});

function updateBatteryBar(id, pct) {
  document.querySelectorAll('.bat-row').forEach(function(row) {
    if (row.querySelector('.bat-id').textContent.trim() === id) {
      var fill = row.querySelector('.bat-fill');
      var label = row.querySelector('.bat-pct');
      fill.style.width = pct + '%';
      fill.style.background = pct < 30 ? '#c0392b' : pct < 60 ? '#8a5a00' : '#2d6a1f';
      label.textContent = pct + '%';
    }
  });
}

// === MISSION STATUS TOPIC ===
var missionTopic = new ROSLIB.Topic({
  ros: ros,
  name: '/mission/status',
  messageType: 'std_msgs/String'
});

missionTopic.subscribe(function(msg) {
  addFeed('blue', msg.data, 'now');
});

// === CLOCK ===
function tick() {
  document.getElementById('clock').textContent = new Date().toLocaleTimeString('en-GB');
}
tick();
setInterval(tick, 1000);

// === TOOLTIP ===
function tip(e, title, status, cargo) {
  var t = document.getElementById('tooltip');
  t.innerHTML = '<strong>' + title + '</strong><br>' + status + '<br><span style="color:#6b6b6b">' + cargo + '</span>';
  t.style.display = 'block';
  var rect = e.currentTarget.ownerSVGElement.parentElement.getBoundingClientRect();
  t.style.left = (e.clientX - rect.left + 12) + 'px';
  t.style.top  = (e.clientY - rect.top  + 12) + 'px';
}
function hideTip() {
  document.getElementById('tooltip').style.display = 'none';
}

// === DISPATCH ===
function dispatch(id, label, drone, eta) {
  var el = document.getElementById(id);
  if (!el || el.classList.contains('done')) return;
  el.classList.add('done');

  var svc = new ROSLIB.Service({
    ros: ros,
    name: '/dispatch_drone',
    serviceType: 'std_srvs/Trigger'
  });
  svc.callService(new ROSLIB.ServiceRequest({}), function() {
    addFeed('blue', drone + ' dispatched to ' + label + ' — ETA ' + eta, 'now');
  });

  var u = parseInt(document.getElementById('k-urgent').textContent) || 0;
  if (u > 0) document.getElementById('k-urgent').textContent = u - 1;
  var d = parseInt(document.getElementById('k-done').textContent) || 0;
  document.getElementById('k-done').textContent = d + 1;
}

function autoDispatch() {
  [
    ['r1','P-041','DR-01','2 min'],
    ['r2','P-033','DR-02','4 min'],
    ['r3','Thameur OR','DR-03','7 min'],
    ['r4','P-058','DR-04','9 min']
  ].forEach(function(r, i) {
    setTimeout(function() { dispatch(r[0], r[1], r[2], r[3]); }, i * 300);
  });
  addFeed('green', 'auto-dispatch: all 4 requests assigned optimally', 'now');
}

// === ACTIVITY LOG ===
function addFeed(type, text, time) {
  var f = document.getElementById('feed');
  var d = document.createElement('div');
  d.className = 'feed-item f-' + type + ' fadein';
  d.innerHTML = '<div class="feed-dot"></div><div class="feed-text">' + text + '</div><span class="feed-time">' + time + '</span>';
  f.insertBefore(d, f.firstChild);
}

// === SIMULATED INCOMING REQUESTS ===
var sims = [
  { name: 'P-072 — oxygen concentrator, COPD', detail: 'Menzah · 3.8 km from Thameur', color: '#8a5a00' },
  { name: 'P-089 — insulin refill', detail: 'Ariana · 4.1 km from C. Nicolle', color: '#c0392b' }
];
var si = 0;
setInterval(function() {
  if (si >= sims.length) return;
  var s = sims[si++];
  var uid = 'r-sim-' + Date.now();
  var list = document.getElementById('req-list');
  var div = document.createElement('div');
  div.className = 'req fadein';
  div.id = uid;
  div.innerHTML =
    '<div class="req-accent" style="background:' + s.color + '"></div>' +
    '<div class="req-body"><div class="req-name">' + s.name + '</div><div class="req-detail">' + s.detail + '</div></div>' +
    '<span class="req-time">just now</span>';
  div.onclick = function() { dispatch(uid, s.name.split(' — ')[0], 'DR-04', '~6 min'); };
  list.appendChild(div);
  addFeed('blue', 'New request: ' + s.name.split(' — ')[0], 'now');
}, 25000);
</script>
