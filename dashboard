<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MediDrone Ops</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#F1EFE8;
  --card:#ffffff;
  --border:#E2E0D8;
  --txt:#1a1a1a;
  --muted:#6b6b6b;
  --subtle:#9a9a9a;
  --red:#c0392b;
  --red-bg:#fdf0ef;
  --blue:#1a5fa8;
  --blue-bg:#eef4fb;
  --green:#2d6a1f;
  --green-bg:#edf5e8;
  --amber:#8a5a00;
  --amber-bg:#fdf5e6;
  --radius:12px;
}
body{
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  background:var(--bg);
  color:var(--txt);
  font-size:13px;
  min-height:100vh;
  padding:20px 24px;
}
.topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px}
.topbar h1{font-size:18px;font-weight:400;letter-spacing:-.3px}
.topbar h1 em{font-style:normal;color:var(--red)}
.topbar-right{display:flex;align-items:center;gap:14px}
.live-indicator{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--muted)}
.live-dot{width:8px;height:8px;border-radius:50%;background:#22c55e;animation:blink 1.6s ease infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
#clock{font-size:13px;color:var(--muted);font-variant-numeric:tabular-nums;letter-spacing:.02em}
.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px 16px}
.kpi-val{font-size:30px;font-weight:400;line-height:1;margin-bottom:6px}
.kpi-label{font-size:13px;color:var(--muted)}
.kv-red{color:var(--red)}
.kv-blue{color:var(--blue)}
.kv-green{color:var(--green)}
.body{display:grid;grid-template-columns:1fr 300px;gap:14px;margin-bottom:14px}
.map-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.map-head{display:flex;align-items:center;justify-content:space-between;padding:11px 16px;border-bottom:1px solid var(--border)}
.map-head-label{font-size:13px;color:var(--muted)}
.legend{display:flex;align-items:center;gap:16px}
.leg{display:flex;align-items:center;gap:5px;font-size:12px;color:var(--muted)}
.leg-sq{width:9px;height:9px;border-radius:2px;background:var(--red);flex-shrink:0}
.leg-circle-r{width:9px;height:9px;border-radius:50%;border:1.5px solid var(--red);flex-shrink:0}
.leg-circle-g{width:9px;height:9px;border-radius:50%;border:1.5px solid var(--green);flex-shrink:0}
.map-svg-wrap{position:relative}
#mapsvg{width:100%;display:block;background:#f4f2ea}
.side{display:flex;flex-direction:column;gap:12px}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px}
.card-title{font-size:13px;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;justify-content:space-between}
.badge{font-size:11px;padding:3px 10px;border-radius:20px;font-weight:400}
.badge-red{background:var(--red-bg);color:var(--red)}
.badge-blue{background:var(--blue-bg);color:var(--blue)}
.badge-green{background:var(--green-bg);color:var(--green)}
.badge-amber{background:var(--amber-bg);color:var(--amber)}
.mission-list{display:flex;flex-direction:column;gap:6px}
.mission{display:flex;align-items:center;justify-content:space-between;padding:9px 11px;border:1px solid var(--border);border-radius:8px;gap:10px}
.m-name{font-size:13px;font-weight:500;margin-bottom:2px}
.m-sub{font-size:11px;color:var(--muted)}
.bat-list{display:flex;flex-direction:column;gap:8px}
.bat-row{display:flex;align-items:center;gap:10px}
.bat-id{font-size:12px;color:var(--muted);min-width:36px}
.bat-track{flex:1;height:5px;background:#e8e6de;border-radius:3px;overflow:hidden}
.bat-fill{height:100%;border-radius:3px}
.bat-pct{font-size:12px;color:var(--muted);min-width:30px;text-align:right}
.bottom{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.req-list{display:flex;flex-direction:column;gap:5px;margin-bottom:10px}
.req{display:flex;align-items:center;gap:10px;padding:9px 12px;border:1px solid var(--border);border-radius:8px;cursor:pointer;transition:background .12s}
.req:hover{background:#fafaf7}
.req.done{opacity:.4;pointer-events:none}
.req-accent{width:3px;height:36px;border-radius:2px;flex-shrink:0}
.req-body{flex:1;min-width:0}
.req-name{font-size:13px;font-weight:400;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.req-detail{font-size:11px;color:var(--muted)}
.req-time{font-size:11px;color:var(--subtle);white-space:nowrap}
.dispatch-btn{width:100%;padding:11px;background:var(--card);border:1px solid var(--border);border-radius:8px;font-size:13px;color:var(--txt);cursor:pointer;transition:background .12s}
.dispatch-btn:hover{background:#fafaf7}
.feed{display:flex;flex-direction:column;gap:5px}
.feed-item{display:flex;align-items:flex-start;gap:8px;padding:8px 10px;border-radius:8px;font-size:12px;line-height:1.45}
.feed-dot{width:6px;height:6px;border-radius:50%;margin-top:3px;flex-shrink:0}
.feed-text{flex:1}
.feed-time{font-size:11px;color:var(--subtle);white-space:nowrap}
.f-red{background:var(--red-bg)}.f-red .feed-dot{background:var(--red)}.f-red .feed-text{color:var(--red)}
.f-amber{background:var(--amber-bg)}.f-amber .feed-dot{background:#c07000}.f-amber .feed-text{color:var(--amber)}
.f-blue{background:var(--blue-bg)}.f-blue .feed-dot{background:var(--blue)}.f-blue .feed-text{color:var(--blue)}
.f-green{background:var(--green-bg)}.f-green .feed-dot{background:var(--green)}.f-green .feed-text{color:var(--green)}
@keyframes fadein{from{opacity:0;transform:translateY(-3px)}to{opacity:1;transform:none}}
.fadein{animation:fadein .25s ease}
.tooltip{
  position:absolute;
  background:var(--card);
  border:1px solid var(--border);
  border-radius:8px;
  padding:8px 12px;
  font-size:11px;
  color:var(--txt);
  pointer-events:none;
  display:none;
  z-index:10;
  min-width:160px;
  line-height:1.6;
}
</style>
<script src="https://cdn.jsdelivr.net/npm/roslib/build/roslib.min.js"></script>
</head>
